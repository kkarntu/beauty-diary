# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=development
PORT=23001
WEB_ORIGIN=http://localhost:23000

# ─── Database (PostgreSQL) ───────────────────────────────
# Host port 5439 → container port 5432 (see infra/docker-compose.yml).
DATABASE_URL=postgres://beauty:beauty@localhost:5439/beauty_diary

# ─── Auth (custom JWT) ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-32+-byte-hex-secret
JWT_REFRESH_SECRET=replace-with-different-32+-byte-hex-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECRET=replace-with-32+-byte-hex-secret
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ─── Mail (Nodemailer SMTP) ──────────────────────────────
# Local dev: Mailpit at localhost:1025 (no auth).
# Prod: Gmail SMTP via App Password.
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Beauty Diary <noreply@beauty-diary.local>"

# ─── Object storage (LocalStack S3 → Cloudflare R2 in prod) ──
S3_ENDPOINT=http://localhost:4569
S3_REGION=us-east-1
S3_BUCKET=beauty-diary-media
S3_ACCESS_KEY_ID=test
S3_SECRET_ACCESS_KEY=test
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=http://localhost:4569/beauty-diary-media

# ─── Misc ────────────────────────────────────────────────
LOG_LEVEL=debug
RATE_LIMIT_AUTH_PER_MINUTE=10
