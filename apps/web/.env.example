# ─── Public (exposed to the browser) ─────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:23000
NEXT_PUBLIC_API_URL=http://localhost:23001
# Used by sitemap.ts and robots.ts. In prod set to your Vercel URL.
NEXT_PUBLIC_SITE_URL=http://localhost:23000

# ─── Server-only (used in Server Components / Route Handlers) ──
# Internal API URL when web and api share a network in prod.
# In dev this is the same as NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=http://localhost:23001

# ─── Telemetry ────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
